# ═══════════════════════════════════════════════════════════════
# Site Audit — переменные окружения
# Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════════════════════

# ── Telegram-бот (ОБЯЗАТЕЛЬНО) ────────────────────────────────
# Токен бота, полученный от @BotFather
TELEGRAM_BOT_TOKEN=

# Список Telegram ID пользователей, которым разрешён доступ к боту.
# Через запятую, без пробелов. Если пусто — доступ есть у всех.
# Пример: 123456789,987654321
ALLOWED_USER_IDS=

# ── Параметры аудита по умолчанию ─────────────────────────────
# Максимальное количество страниц при обходе по ссылкам (если нет sitemap)
DEFAULT_MAX_CRAWL_PAGES=500

# Максимальная глубина BFS-обхода
DEFAULT_MAX_DEPTH=3

# Ограничение общего числа URL для проверки (0 = без лимита)
DEFAULT_LIMIT=0

# Количество параллельных потоков загрузки
DEFAULT_WORKERS=10

# Задержка между запросами в секундах
DEFAULT_DELAY=0.0

# Таймаут HTTP-запросов в секундах
DEFAULT_TIMEOUT=15

# Минимальная длина видимого текста для определения пустой страницы (символов)
DEFAULT_MIN_TEXT_LENGTH=100

# Порог тяжёлой картинки (КБ)
DEFAULT_MAX_IMAGE_SIZE_KB=500

# Проверять внешние ссылки (true/false)
DEFAULT_CHECK_EXTERNAL_LINKS=false

# ── Отчёты ────────────────────────────────────────────────────
# Директория для сохранения отчётов
OUTPUT_DIR=./reports

# Имя Excel-файла отчёта
EXCEL_REPORT_NAME=audit_report.xlsx

# Имя HTML-файла отчёта
HTML_REPORT_NAME=audit_report.html

# ── Логирование ──────────────────────────────────────────────
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу логов (папка создаётся автоматически)
LOG_FILE_PATH=./logs/app.log

# Максимальный размер файла лога в байтах (по умолчанию 10 МБ)
LOG_MAX_BYTES=10485760

# Количество файлов ротации логов
LOG_BACKUP_COUNT=5
